# LLM — any OpenAI-compatible endpoint. Calls walk a chain:
#   primary  ->  fallback  ->  deterministic
# so a rate limit on one provider cannot take the demo down. Leave both keys
# empty to run fully offline on deterministic fallbacks.

# Primary: Groq (console.groq.com). Free tier is generous but the small model
# has a 6k tokens/minute cap, which the auditor's probe battery can reach.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_MODEL_CHEAP=llama-3.1-8b-instant

# Fallback: Gemini (aistudio.google.com/apikey). Used automatically when the
# primary errors or is rate-limited. Prefer a non-thinking model — reasoning
# models spend the token budget on thought and can return empty completions.
LLM_FALLBACK_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=gemini-flash-lite-latest
LLM_FALLBACK_MODEL_CHEAP=gemini-flash-lite-latest

# Optional third provider. Free-tier quota is per key, so a second key on the
# same vendor still buys an independent budget. Any OpenAI-compatible endpoint
# works here; leave empty if you only have two.
LLM_FALLBACK2_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_FALLBACK2_API_KEY=
LLM_FALLBACK2_MODEL=gemini-flash-lite-latest
LLM_FALLBACK2_MODEL_CHEAP=gemini-flash-lite-latest

# Masumi payment service (self-hosted, Docker). Leave the API key empty to run
# the built-in mock payment client (identical interface, mock_tx_* refs).
MASUMI_PAYMENT_SERVICE_URL=http://localhost:3001/api/v1
MASUMI_PAYMENT_API_KEY=
MASUMI_NETWORK=Preprod

# Cardano Preprod (TESTNET ONLY — never put mainnet credentials here).
# The Blockfrost key grants READ access: enough to show the live chain tip and
# prove the system is really talking to Cardano. Submitting transactions also
# needs a funded wallet below — until then the quarantine gate is evaluated
# locally against the same compiled validators and reported as "simulated".
BLOCKFROST_PROJECT_ID_PREPROD=
CARDANO_WALLET_MNEMONIC=

# Services
REGISTRY_PORT=4100
AGENTS_PORT=4300
# Where the registry can reach the agents (public URL when deployed)
AGENTS_PUBLIC_URL=http://localhost:4300
# Where the agents can reach the registry (public URL when deployed)
REGISTRY_URL=http://localhost:4100
